{
  "title": "monitoring",
  "tags": ["hotel-booking"],
  "timezone": "browser",
  "schemaVersion": 36,
  "refresh": "10s",
  "panels": [
    {
      "title": "Frontend CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"hotel-booking\", pod=~\"react-frontend-.*\", container!=\"POD\", container!=\"\"}[5m])) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Backend CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"hotel-booking\", pod=~\"spring-backend-.*\", container!=\"POD\", container!=\"\"}[5m])) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Frontend Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"hotel-booking\", pod=~\"react-frontend-.*\", container!=\"POD\", container!=\"\"}) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "title": "Backend Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"hotel-booking\", pod=~\"spring-backend-.*\", container!=\"POD\", container!=\"\"}) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "title": "Backend HTTP Requests (Application)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{namespace=\"hotel-booking\"}[5m])) by (uri)",
          "legendFormat": "{{uri}}",
          "refId": "A"
        }
      ]
    }
  ]
}
